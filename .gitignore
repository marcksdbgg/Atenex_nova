# ===========================================================================
# Atenex Nova — .gitignore
# ===========================================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
parts/
var/
wheels/
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
.venv/
.venv*/
venv/
ENV/
env/
.env
.env.local
.env.*.local

# TurboVec storage
backend/storage/turbovec/
storage/turbovec/

# ---------------------------------------------------------------------------
# Node / React Frontend
# ---------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js
.next/
out/

# ---------------------------------------------------------------------------
# IDE / Editors
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
docker-compose.override.yml

# ---------------------------------------------------------------------------
# Qdrant local data
# ---------------------------------------------------------------------------
qdrant_data/
qdrant_storage/

# ---------------------------------------------------------------------------
# Model files (large binaries)
# ---------------------------------------------------------------------------
models/
*.gguf
*.bin
*.safetensors
*.pt
*.onnx

# ---------------------------------------------------------------------------
# Blob store (uploaded documents)
# ---------------------------------------------------------------------------
blob_store/
storage/uploads/
storage/visual_pages/
storage/observability/
backend/storage/uploads/
backend/storage/visual_pages/
backend/storage/observability/

# ---------------------------------------------------------------------------
# Database files
# ---------------------------------------------------------------------------
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite3

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
logs/
*.log

# ---------------------------------------------------------------------------
# Test / Coverage
# ---------------------------------------------------------------------------
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
.pytest_cache/
nosetests.xml
coverage.xml
*.cover
*.py,cover

# ---------------------------------------------------------------------------
# Mypy / Type checking
# ---------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json

# ---------------------------------------------------------------------------
# Ruff
# ---------------------------------------------------------------------------
.ruff_cache/

# ---------------------------------------------------------------------------
# Jupyter
# ---------------------------------------------------------------------------
.ipynb_checkpoints/

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
*.bak
*.tmp
*.temp
scratch/
tmp-audit-debug/

# ---------------------------------------------------------------------------
# GitHub customizations
# ---------------------------------------------------------------------------
!.github/
!.github/**
